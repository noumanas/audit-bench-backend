# Database
DATABASE_URL="postgresql://macbookpro2018@localhost:5432/ai_code_auditor?schema=public"

# Server
PORT=4000
FRONTEND_ORIGIN="http://localhost:3000"

# LLM providers — set the ones you plan to use.
# Which provider is used per-request is chosen by "provider" in the API call,
# falling back to DEFAULT_LLM_PROVIDER.
DEFAULT_LLM_PROVIDER="anthropic"

ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"

GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-pro"

# Optional — a stronger/pricier model used only to double-check findings
# that come back high-severity but low-confidence (see PipelineService).
# Leave unset to skip escalation entirely (default, cheapest).
# ANTHROPIC_ESCALATION_MODEL="claude-opus-4-5"
# OPENAI_ESCALATION_MODEL="gpt-5"
# GEMINI_ESCALATION_MODEL="gemini-2.5-pro"

# Repo scan limits — each file that Stage 1 flags as risky is one LLM
# request; files Stage 1 clears cost nothing. Keep these conservative.
MAX_SCAN_FILES=15
MAX_FILE_SIZE_BYTES=100000

# Auth — generate your own: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET="changeme"
JWT_EXPIRES_IN="7d"

# Optional — only needed for self-hosted GitLab instances.
# GITLAB_BASE_URL="https://gitlab.example.com/api/v4"

# The account that signs up with this email becomes a super_admin
# automatically — the only way to bootstrap the first admin account.
SUPER_ADMIN_EMAIL="you@example.com"
