// AI Code Auditor — data model
// Two report kinds share one mental model: an Audit is a single-file/paste
// review; a ScanJob is a repository-wide review composed of many ScanFiles.
// Both belong to a User, whose Plan governs daily/monthly audit quotas.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Verdict {
  pass
  needs_work
  do_not_ship
}

enum ScanStatus {
  queued
  processing
  completed
  failed
}

enum ScanSourceType {
  zip
  github_repo
  github_pr
  gitlab_repo
  gitlab_mr
}

enum Role {
  user
  admin
  super_admin
}

enum PlanRequestStatus {
  pending
  approved
  rejected
}

// Org-level permissions — distinct from the platform-wide `Role` enum
// (user/admin/super_admin), which governs access to the internal admin
// panel and has nothing to do with team membership.
enum OrgRole {
  owner
  admin
  member
}

enum InviteStatus {
  pending
  accepted
  revoked
  expired
}

model Plan {
  id                String         @id @default(uuid())
  slug              String         @unique // "free" | "pro" | "team" | "enterprise"
  name              String
  priceMonthlyCents Int            @default(0)
  // null = unlimited
  dailyAuditLimit   Int?
  monthlyAuditLimit Int?
  repositoryScan    Boolean        @default(true)
  createdAt         DateTime       @default(now())
  users             User[]
  organizations     Organization[]
  planRequests      PlanRequest[]
}

// A shared workspace: members see each other's audits/scans/analytics and
// draw from one pooled plan/quota (see QuotaService, AnalyticsService,
// AuditService, RepositoryService — all branch on User.organizationId).
// Deliberately one-org-per-user in this version — no org switcher, no
// nested teams. A user's history from before joining stays personal (see
// Audit.organizationId / ScanJob.organizationId being nullable + the
// OR-scope query pattern in workspace-scope.ts) rather than being migrated
// in, so joining a team never exposes or reassigns someone's past work.
model Organization {
  id           String               @id @default(uuid())
  name         String
  slug         String               @unique
  plan         Plan                 @relation(fields: [planId], references: [id])
  planId       String
  createdAt    DateTime             @default(now())
  members      User[]               @relation("OrganizationMembers")
  invites      OrganizationInvite[]
  planRequests PlanRequest[]        @relation("PlanRequestsByOrganization")
  audits       Audit[]
  scanJobs     ScanJob[]
}

// Invite by email — the only join path in this version (no public
// invite-link browsing). `token` is the unguessable part of the accept URL,
// same pattern as OAuthLoginCode/badgeToken elsewhere in this schema.
model OrganizationInvite {
  id             String       @id @default(uuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  email          String
  role           OrgRole      @default(member)
  token          String       @unique
  invitedBy      User         @relation("OrgInvitesSent", fields: [invitedById], references: [id])
  invitedById    String
  status         InviteStatus @default(pending)
  createdAt      DateTime     @default(now())
  expiresAt      DateTime
  acceptedAt     DateTime?

  @@index([organizationId])
  @@index([email])
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  // Null for an account created via GitHub/GitLab OAuth (no password ever
  // set) — see AuthService.login, which rejects password login for these.
  passwordHash    String?
  name            String?
  plan            Plan          @relation(fields: [planId], references: [id])
  planId          String
  role            Role          @default(user)
  // Flipped off by an admin to lock the account out immediately (checked at
  // login and on every authenticated request via JwtStrategy) without
  // deleting any of the user's data.
  isActive        Boolean       @default(true)
  // Personal Access Tokens for repo listing/scanning — plaintext in this
  // dev-scoped build; a real deployment would encrypt these at rest.
  githubToken     String?
  githubUsername  String?
  gitlabToken     String?
  gitlabUsername  String?
  // GitLab OAuth access tokens (unlike a pasted PAT, or GitHub's classic
  // OAuth App tokens) expire after ~2h — these let GitlabService silently
  // refresh gitlabToken before it goes stale. Unused for a pasted PAT.
  gitlabRefreshToken   String?
  gitlabTokenExpiresAt DateTime?
  // Public, unguessable token used in the README badge URL — distinct from
  // `id` so a leaked badge URL can't be used to look up the account by id
  // and can be rotated independently. Generated on first request.
  badgeToken      String?       @unique
  // Long-lived credential for the CLI/CI (see auth/api-key.util.ts,
  // JwtAuthGuard) — grants full API access as this user, unlike badgeToken
  // (read-only, meant to be public). Prefixed "abk_" so JwtAuthGuard can
  // tell it apart from a real JWT without attempting to verify it as one.
  apiKey          String?       @unique
  createdAt       DateTime      @default(now())
  audits          Audit[]
  scanJobs        ScanJob[]
  planRequests    PlanRequest[] @relation("PlanRequestsByUser")
  // Requests this user reviewed as an admin/super_admin — distinct relation
  // from the requests they themselves filed.
  reviewedPlanRequests PlanRequest[] @relation("PlanRequestsReviewedBy")
  webhookConfigs  WebhookConfig[]
  oauthAccounts   OAuthAccount[]
  oauthLoginCodes OAuthLoginCode[]
  // Nullable — most users are on a personal plan and never join a team.
  // When set, this user's quota/plan/audits/scans are org-scoped instead of
  // personal (see QuotaService, AuditService, RepositoryService).
  organization    Organization?    @relation("OrganizationMembers", fields: [organizationId], references: [id], onDelete: SetNull)
  organizationId  String?
  orgRole         OrgRole?
  sentOrgInvites  OrganizationInvite[] @relation("OrgInvitesSent")

  @@index([organizationId])
}

// Identifies a user by the provider's own stable account id — never by
// email — so a same-email GitHub/GitLab account can never silently sign
// into an existing password-based account (see AuthOAuthService).
model OAuthAccount {
  id             String   @id @default(uuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  provider       String // 'github' | 'gitlab'
  providerUserId String
  createdAt      DateTime @default(now())

  @@unique([provider, providerUserId])
}

// A one-time, short-lived code handed to the browser in the OAuth
// redirect's query string instead of the real JWT — the frontend exchanges
// it server-side for the actual session, so the access token itself never
// appears in a URL, browser history, or Referer header.
model OAuthLoginCode {
  id        String    @id @default(uuid())
  code      String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// Manually configured by the user in their repo/project's webhook settings
// (no GitHub App / OAuth — this integration is PAT-only) so an incoming
// webhook can be matched to (a) whose token to reply with and (b) the
// secret to verify the delivery against.
model WebhookConfig {
  id             String   @id @default(uuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  provider       String // 'github' | 'gitlab'
  // GitHub: "owner/repo" (matches repository.full_name).
  // GitLab: the numeric project id, as a string (matches project.id).
  repoIdentifier String
  secret         String
  createdAt      DateTime @default(now())

  @@unique([provider, repoIdentifier])
}

// A user's self-service plan switch is only instant for the free tier —
// requesting a paid plan (Pro/Team/Enterprise) files one of these instead,
// and an admin/super_admin must approve it before the plan actually changes.
model PlanRequest {
  id              String            @id @default(uuid())
  // Who filed the request — always set, even for an org-targeted request
  // (the org owner/admin who clicked "Request"), so the admin panel can
  // still show who to follow up with.
  user            User              @relation("PlanRequestsByUser", fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  // Set when this is a request to change the requester's ORGANIZATION plan
  // rather than their personal one — see UsersService.changePlan, which
  // branches on whether the requester is in an org.
  organization    Organization?     @relation("PlanRequestsByOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String?
  requestedPlan   Plan              @relation(fields: [requestedPlanId], references: [id])
  requestedPlanId String
  status          PlanRequestStatus @default(pending)
  reviewedBy      User?             @relation("PlanRequestsReviewedBy", fields: [reviewedById], references: [id])
  reviewedById    String?
  note            String? // optional reviewer note, mainly used on rejection
  createdAt       DateTime          @default(now())
  reviewedAt      DateTime?

  @@index([userId])
  @@index([organizationId])
  @@index([status])
}

model Audit {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  // Set at creation time from User.organizationId — makes this audit
  // visible to the whole team (see workspace-scope.ts), not just its
  // creator. Null for personal-account audits, or any audit run before the
  // creator joined an org (that history stays personal, never migrated in).
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  organizationId String?
  filename  String
  language  String?
  provider  String
  verdict   Verdict
  summary   String
  findings  Json // Finding[] — see src/audit/finding.types.ts
  // Free, local-only checks (ESLint/TSC/complexity/formatting/risk triage) —
  // see src/audit/stage1/types.ts. Always populated, even on a pure Stage 1 run.
  stage1    Json?
  // False when Stage 1 found nothing worth escalating and no LLM call was
  // made — these runs don't consume plan quota. True on a cache hit that
  // was originally AI-reviewed.
  aiInvoked Boolean  @default(true)
  fromCache Boolean  @default(false)
  codeSize  Int
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([organizationId])
}

// Keyed by a hash of (content + provider + focus areas) so re-auditing
// unchanged code — the common case when the same file is scanned across
// repeated repo scans, or a user re-runs an audit — costs nothing.
model AuditCache {
  id          String   @id @default(uuid())
  contentHash String   @unique
  verdict     Verdict
  summary     String
  findings    Json
  stage1      Json?
  aiInvoked   Boolean  @default(false)
  hitCount    Int      @default(0)
  createdAt   DateTime @default(now())
  lastHitAt   DateTime @default(now())
}

model ScanJob {
  id           String     @id @default(uuid())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  // Same team-visibility rule as Audit.organizationId — see there.
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  organizationId String?
  sourceName   String // original zip filename, "owner/repo", or "owner/repo#12"
  sourceType   ScanSourceType @default(zip)
  pullRequestUrl String? // set for github_pr / gitlab_mr
  // Set for github_pr / gitlab_mr — everything PrFeedbackService needs to
  // post the review comments / summary / commit status back once the scan
  // completes. Shape: PrContext (see src/pr-feedback/pr-feedback.types.ts).
  prContext      Json?
  // Set for github_repo / gitlab_repo — what FixService needs to branch off
  // and open a PR/MR when the user commits a fix from the web editor.
  // Shape: RepoRef (see src/common/repo-ref.types.ts).
  repoRef        Json?
  status       ScanStatus @default(queued)
  provider     String
  framework    String? // best-guess detected framework
  fileCount    Int        @default(0)
  filesScanned Int        @default(0)
  verdict      Verdict?
  summary      String?
  // Aggregate cross-file analysis, see src/repository/repo-analysis.types.ts
  dependencyGraph Json?
  circularImports Json?
  deadCode        Json?
  duplicates      Json?
  secrets         Json?
  dependencyVulnerabilities Json? // DependencyVulnerability[] — see analysis/dependency-audit.ts
  // Cost-saving summary for this scan — see RepositoryService.processScan.
  filesFromCache Int @default(0)
  filesAiSkipped Int @default(0) // Stage 1 found nothing risky; no LLM call made
  // True only if at least one file in this scan triggered a FRESH LLM call
  // (not served from cache) — this, not fileCount, is what quota counts.
  aiInvoked   Boolean    @default(true)
  error       String?
  createdAt   DateTime   @default(now())
  // Bumped on every status/progress write during processScan — used by
  // ScanJobSweepService to tell "still actively running" apart from "the
  // process died mid-scan and this will never move again."
  updatedAt   DateTime   @updatedAt
  completedAt DateTime?
  files       ScanFile[]

  @@index([userId])
  @@index([organizationId])
  @@index([status, updatedAt])
}

model ScanFile {
  id        String   @id @default(uuid())
  scanJob   ScanJob  @relation(fields: [scanJobId], references: [id], onDelete: Cascade)
  scanJobId String
  path      String
  language  String?
  verdict   Verdict?
  findings  Json // Finding[]
  stage1    Json?
  aiInvoked Boolean  @default(true)
  fromCache Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([scanJobId])
}
